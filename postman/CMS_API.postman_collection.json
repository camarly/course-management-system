{
  "info": {
    "name": "CMS API",
    "description": "Course Management System (LMS) — full API surface for COMP3161 final project.\n\nAuth: JWT bearer token. The collection-level pre-request script automatically logs in using `{{test_username}}` and `{{test_password}}` from the active environment and stores the token in `{{jwt_token}}`. Public routes (login, register, health) opt out of bearer auth at the request level.\n\nEnvelope: every endpoint returns either `{ \"data\": ..., \"message\": ... }` or `{ \"error\": ..., \"message\": ... }`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "cms-api-2026"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{jwt_token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-login: if no jwt_token in the active environment, hit /api/auth/login",
          "// and stash the returned token. Subsequent requests reuse it via the",
          "// collection-level Bearer auth ({{jwt_token}}).",
          "if (!pm.environment.get('jwt_token')) {",
          "    const baseUrl = pm.environment.get('base_url');",
          "    if (!baseUrl) {",
          "        console.warn('No base_url set in environment — skipping auto-login.');",
          "        return;",
          "    }",
          "    pm.sendRequest({",
          "        url: baseUrl + '/api/auth/login',",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' },",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                username: pm.environment.get('test_username'),",
          "                password: pm.environment.get('test_password')",
          "            })",
          "        }",
          "    }, function (err, res) {",
          "        if (err) { console.error('Auto-login request failed:', err); return; }",
          "        let body;",
          "        try { body = res.json(); } catch (_) { body = null; }",
          "        const token = body && body.data && body.data.token;",
          "        if (token) {",
          "            pm.environment.set('jwt_token', token);",
          "            console.log('jwt_token set via auto-login');",
          "        } else {",
          "            console.warn('Login did not return data.token. Response:', body);",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "default" }
  ],
  "item": [
