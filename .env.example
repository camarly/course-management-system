# ── Database ─────────────────────────────────────────────────────────────────
# Use "db" as host when running via Docker Compose; "localhost" for bare-metal
DB_HOST=db
DB_PORT=3306
DB_NAME=lms_db
DB_USER=lms_user
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use "redis" as host when running via Docker Compose; "localhost" for bare-metal
REDIS_URL=redis://redis:6379/0

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-do-not-use-in-production-9f2c4a8d3b1e7f6a

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-do-not-use-in-production-5e8b2c7f4a9d1e3c
JWT_EXPIRY_HOURS=24

# ── Celery ────────────────────────────────────────────────────────────────────
# Use "redis" as host when running via Docker Compose; "localhost" for bare-metal
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
