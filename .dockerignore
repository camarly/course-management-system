!.env.example
*.pem
*.key
*.cert
*.p12

# ── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ──────────────────────────────────────────────────────────────────
docker-compose.yml
docker-compose.override.yml

